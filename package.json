{
  "name": "a2a-protocol",
  "version": "0.1.0",
  "description": "Agent-to-Agent Communication Protocol - MVP",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "server": "ts-node src/server.ts",
    "agent:a": "ts-node src/examples/agent-a.ts",
    "agent:b": "ts-node src/examples/agent-b.ts",
    "agent:market": "ts-node src/examples/market-agent.ts",
    "agent:data": "ts-node src/examples/data-agent.ts",
    "agent:orchestrator": "ts-node src/examples/orchestrator.ts",
    "agent:openclaw": "ts-node src/examples/openclaw-integration.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": ["agent", "a2a", "ai", "protocol"],
  "author": "OpenAWS Community",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/jest": "^29.5.11",
    "@types/supertest": "^6.0.2",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3"
  }
}
